{
  "name": "make-me-survive",
  "version": "1.0.0",
  "description": "Offline survival encyclopedia with AI assistant — works as web app and Android APK",
  "main": "src/index.html",
  "scripts": {
    "start": "npx serve src -p 3000",
    "preview": "npx serve src -p 3000 --open",
    "sync": "npx cap sync android",
    "open:android": "npx cap open android",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "build:android:release": "cd android && ./gradlew assembleRelease",
    "cap:init": "npx cap init 'Survival Encyclopedia' com.makemesurvive.app --web-dir src",
    "cap:add:android": "npx cap add android",
    "setup": "npm install && echo 'Done. Run: npm run cap:init, then npm run cap:add:android'"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "serve": "^14.2.0"
  },
  "keywords": ["survival", "offline", "encyclopedia", "android", "capacitor"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/make-me-survive.git"
  }
}
