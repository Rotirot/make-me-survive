{
  "name": "make-me-survive",
  "version": "1.3.0",
  "description": "Offline survival encyclopedia — single HTML file, works as web app and Android APK",
  "main": "survival_encyclopedia.html",
  "scripts": {
    "start": "npx serve . -p 3000 --single survival_encyclopedia.html",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "sync": "npx cap sync android",
    "open:android": "npx cap open android",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "build:android:release": "cd android && ./gradlew assembleRelease",
    "cap:init": "npx cap init 'Survival Encyclopedia' com.makemesurvive.app --web-dir .",
    "cap:add:android": "npx cap add android"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "coverageReporters": ["text", "lcov"]
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "jest": "^29.7.0",
    "serve": "^14.2.0"
  },
  "keywords": ["survival", "offline", "encyclopedia", "android", "capacitor", "first-aid"],
  "license": "CC-BY-NC-SA-4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rotirot/make-me-survive.git"
  }
}
